# Server Config
PORT=3000

# Jira Connection (Dành cho Phase gọi cronjob/API - Tạm để sẵn)
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_USERNAME=your_email@company.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEY=PROJ

# Platform Config (Telegram hoặc Teams)
# Cấu hình chọn luồng gửi báo cáo: 'teams', 'telegram' hoặc 'both'
ACTIVE_NOTIFICATION_PLATFORM=teams

# Nếu Test trên Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_TEST_GROUP_ID=-123456789

# Nếu Test trên Microsoft Teams
TEAMS_WEBHOOK_URL=https://your-company.webhook.office.com/webhookb2/...

# Sprint Effort Threshold Configurations (Hours)
SPRINT_UNDERLOAD_HOURS=10
SPRINT_OVERLOAD_HOURS=40

# Cron Schedule (5 trường: phút giờ ngày tháng thứ)
# Code sẽ tự động chuyển sang 6 trường (thêm giây) cho thư viện 'cron'
# Ví dụ:
#   Mỗi phút (test):       '* * * * *'
#   Mỗi giờ 1 lần:         '0 * * * *'
#   Nhiều khung giờ:        '0 8,13,17 * * *'  (8h, 13h, 17h)
#   Giờ hành chính:         '0 9 * * 1-5'      (9h sáng T2-T6)
CRON_SCHEDULE="0 9 * * 1-5"
